@model List<Mozaic.PasswordManager.Web.Models.ViewModels.UserAccountViewModel>

<h2>User Accounts</h2>

<table class="table">
    <thead>
        <tr>
            <th>Account Name</th>
            <th>User Name</th>
            <th>Password</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var account in Model)
        {
            <tr>
                <td>@account.AccountName</td>
                <td>@account.UserName</td>
                <td>****</td> 
                <td>
                    <a href="@Url.Action("ViewPassword", "UserAccount", new { id = account.Id })" class="btn btn-primary" title="View Password">
                        <i class="fas fa-eye"></i> 
                    </a>

                </td>
            </tr>
        }
    </tbody>
</table>

